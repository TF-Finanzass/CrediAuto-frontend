  "help": {
    "title": "Help & Support",
    "faq": {
      "title": "Frequently Asked Questions",
      "q1": {
        "question": "How do I calculate a new credit?",
        "answer": "Go to the Simulator section, fill in the client, vehicle, and credit details, then click Calculate. Once you're happy with the result, click Save to generate the schedule."
      },
      "q2": {
        "question": "What is the Balloon payment?",
        "answer": "It's an extra payment at the end of the credit (Smart Purchase style), calculated as a percentage of the vehicle price, that grows with interest throughout the term and is paid together with the last installment."
      },
      "q3": {
        "question": "What does the grace period mean?",
        "answer": "It's a period at the start of the credit where no regular installment is paid. Full grace charges nothing (interest is compounded); partial grace only charges interest and life insurance."
      },
      "q4": {
        "question": "How do I change the currency or exchange rate?",
        "answer": "In Settings you can choose Soles or Dollars as the active currency, and edit the exchange rate (only available when the active currency is Dollars)."
      },
      "q5": {
        "question": "Can I view the schedule after saving it?",
        "answer": "Yes, in the Schedules section you'll find all saved operations. Click \"View schedule\" to see the full installment detail for each one."
      }
    },
